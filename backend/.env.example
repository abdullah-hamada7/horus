# Supabase PostgreSQL Connection String
# Get this connection string from Supabase dashboard -> Project Settings -> Database -> Connection Strings (URI)
# Make sure to use the transaction pooler (port 6543) or session pooler (port 5432) as desired.
# Format: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
